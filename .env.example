# Amarktai Network
# Copy to .env and replace placeholders. Never commit secrets.

# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://amarktai:REPLACE_PASSWORD@127.0.0.1:5432/amarktai"
SESSION_SECRET="REPLACE_WITH_64_HEX_CHARACTERS"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Set to "true" in production (HTTPS required for secure cookies)
COOKIE_SECURE="true"
# AES-256-GCM key for API key encryption at rest (32 random bytes, hex-encoded)
VAULT_ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARACTERS"

# ── Approved AI Providers ─────────────────────────────────────────────────────
# GenX — primary gateway (routes to GPT-4o, Claude, Gemini, DeepSeek etc.)
GENX_API_KEY=""
GENX_BASE_URL="https://query.genx.sh"

# Hugging Face — open-source models, embeddings, TTS, STT
HF_TOKEN=""

# Qwen / DashScope / WanX — Alibaba Cloud: chat, vision, image/video generation
QWEN_API_KEY=""

# Xiaomi MiMo — reasoning model
MIMO_API_KEY=""

# Groq — ultra-low-latency inference (Llama, Mixtral, Whisper)
GROQ_API_KEY=""

# Together AI — open-source model hosting (Llama, FLUX, etc.)
TOGETHER_API_KEY=""

# ── Infrastructure ────────────────────────────────────────────────────────────
GITHUB_PAT=""
REDIS_URL="redis://127.0.0.1:6379"
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_API_KEY=""

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DRIVER="local_vps"
STORAGE_ROOT="/var/www/amarktai/storage"
# Set to "false" in production — dev fallback must be explicitly enabled
AMARKTAI_ALLOW_DEV_STORAGE_FALLBACK="false"

# ── Notifications ─────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Amarktai Network <noreply@amarktai.co.za>"
CONTACT_EMAIL=""
ALERT_EMAIL=""

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# ADMIN_PASSWORD is a bootstrap-only fallback. Remove it after creating a DB
# admin user via the onboarding wizard.
WEBDOCK_API_KEY=""
ADMIN_EMAIL="admin@amarktai.co.za"
ADMIN_PASSWORD="REPLACE_WITH_SECURE_PASSWORD"

# ── Realtime ──────────────────────────────────────────────────────────────────
REALTIME_SERVICE_URL="http://localhost:3001"
